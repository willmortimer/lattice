use flake

# Non-secret local overrides only (e.g. LATTICE_DEV_HOME). Never put API
# tokens or Apple passwords here — those live in secrets/*.env (sops + age).
dotenv_if_exists .env

# Decrypt tracked sops secrets into the environment when age key is present.
# Private key: ~/.config/sops/age/keys.txt  (not in the repo)
# Encrypted files under secrets/ are intentionally committed (public-repo safe).
if has sops; then
  watch_file .sops.yaml
  _lt_sops_env="$(mktemp "${TMPDIR:-/tmp}/lattice-sops.XXXXXX")"
  # shellcheck disable=SC2064
  trap "rm -f '${_lt_sops_env}'" EXIT
  for _lt_sops_file in secrets/cloudflare.env secrets/apple.env; do
    if [[ -f "${_lt_sops_file}" ]]; then
      watch_file "${_lt_sops_file}"
      if sops -d "${_lt_sops_file}" > "${_lt_sops_env}"; then
        dotenv "${_lt_sops_env}"
      fi
    fi
  done
  rm -f "${_lt_sops_env}"
  trap - EXIT
  unset _lt_sops_env _lt_sops_file
fi
