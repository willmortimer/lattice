use flake

# Non-secret / privileged local overrides (Apple signing, etc.). Never put
# API tokens here — those live in secrets/*.env (sops + age).
dotenv_if_exists .env

# Decrypt tracked sops secrets into the environment when age key is present.
# Private key: ~/.config/sops/age/keys.txt  (not in the repo)
if has sops && [[ -f secrets/cloudflare.env ]]; then
  watch_file secrets/cloudflare.env
  watch_file .sops.yaml
  # Prefer a temp file over process substitution: safer across bash/zsh direnv.
  _lt_sops_env="$(mktemp "${TMPDIR:-/tmp}/lattice-sops.XXXXXX")"
  # shellcheck disable=SC2064
  trap "rm -f '${_lt_sops_env}'" EXIT
  if sops -d secrets/cloudflare.env > "${_lt_sops_env}"; then
    dotenv "${_lt_sops_env}"
  fi
  rm -f "${_lt_sops_env}"
  trap - EXIT
  unset _lt_sops_env
fi
