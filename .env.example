# Lattice — environment variables
#
# No variables are currently required: the app is local-first, with no
# API keys or backend endpoints. This file exists so future additions have
# an obvious home. Full inventory: docs/dev/environment.md
#
# Copy to .env if you ever need one (never commit .env).

## Developer convenience (optional)
# LATTICE_DEV_HOME is set to an absolute repo-root/target/dev-home by `pnpm tauri:dev`.
# LATTICE_DEV_RESET_DEMO=1 is also set by default so First Look re-seeds each launch.
# Debug builds without profile env vars also default to target/dev-home (First Look).
# Relative values are also accepted and resolved against the process cwd.
# LATTICE_DEV_HOME=target/dev-home
# LATTICE_DEV_RESET_DEMO=1          # wipe/re-seed First Look (default for tauri:dev)
# LATTICE_HOME=/path/to/profile     # override dev default or ~/Lattice (Personal seeding)
# LATTICE_FORCE_PROD_HOME=1         # debug only: use ~/Lattice instead of target/dev-home
# RUST_BACKTRACE=1
# RUST_LOG=debug            # not yet wired to a logger

## Local macOS install (`nxr desktop-install` / `nix run .#desktop-install`)
# Prefer sops (see secrets/README.md) — not plaintext .env:
#   sops secrets/apple.env
#   direnv reload
# Quote identities (spaces break dotenv/direnv):
# APPLE_SIGNING_IDENTITY="Apple Development: you@example.com (XXXXXXXXXX)"
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_ID=you@example.com          # account email (not the team id)
# APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx  # app-specific password, not login password
# Optional install destination (default: /Applications)
# LATTICE_INSTALL_DIR=/Applications

## Semantic search / embeddings (optional)
# Skip Qwen3 GGUF download on enable (CI / offline Fake worker). Default for tests.
# LATTICE_SEMANTIC_FAKE=1
# Offline fixture: local file copied+sha256-verified instead of HTTPS download.
# LATTICE_SEMANTIC_MODEL_SOURCE=/path/to/Qwen3-Embedding-0.6B-Q8_0.gguf
# Models land under ~/Library/Application Support/Lattice/Models/embeddings/ (or
# $LATTICE_HOME/Models / $LATTICE_DEV_HOME/Models in profile overrides).

## Release signing / notarization (APPLE_ID / APPLE_PASSWORD via sops)
# TAURI_SIGNING_PRIVATE_KEY=          # Tauri updater artifacts only
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
# APPLE_ID=                           # in secrets/apple.env (sops)
# APPLE_PASSWORD=                     # app-specific password in secrets/apple.env

## Site publish / Cloudflare Pages
# Prefer sops (see secrets/README.md) — not plaintext .env:
#   sops secrets/cloudflare.env
#   nix run .#site-deploy
# Or one-shot: sops exec-env secrets/cloudflare.env -- nix run .#site-deploy
# CLOUDFLARE_API_TOKEN=               # Account → Cloudflare Pages → Edit
# CLOUDFLARE_ACCOUNT_ID=              # optional; already in secrets/cloudflare.env
