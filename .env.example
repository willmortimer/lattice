# Lattice — environment variables
#
# No variables are currently required: the app is local-first, with no
# API keys or backend endpoints. This file exists so future additions have
# an obvious home. Full inventory: docs/dev/environment.md
#
# Copy to .env if you ever need one (never commit .env).

## Developer convenience (optional)
# LATTICE_DEV_HOME=target/dev-home   # set automatically by desktop-dev / pnpm tauri:dev
# LATTICE_HOME=/path/to/profile     # override ~/Lattice (ignored when LATTICE_DEV_HOME is set)
# RUST_BACKTRACE=1
# RUST_LOG=debug            # not yet wired to a logger

## Release signing (future — not read by any code yet)
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=
# APPLE_SIGNING_IDENTITY=
