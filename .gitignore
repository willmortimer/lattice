# OS
.DS_Store
Thumbs.db

# Rust
target/

# Node
node_modules/
.pnpm-store/
dist/
*.tsbuildinfo
.astro/

# Site: generated docs content (synced from /docs by scripts/sync-docs.mjs)
site/src/content/docs/
site/src/generated/

# Tauri
apps/desktop/src-tauri/gen/

# Nix / direnv
.direnv/
result

# Editors
.idea/
*.swp
.vscode/

# AI / agent tooling (local session state — never commit)
.claude/
.cursor/
.codex/
.continue/
.aider*
.windsurf/
.copilot/
.agent/
.agents/
.mcp.json
.mcp.jsonc

# Local env (plaintext only). Encrypted sops files under secrets/ are tracked
# on purpose — ciphertext is safe in a public repo; age private keys are not.
.env
.env.*
!.env.example
# Accidental plaintext dumps from sops / manual decrypt
secrets/*.decrypted
secrets/*.plain
secrets/*.clear
# Never commit the age private key even if copied into the tree by mistake
**/age/keys.txt
**/*.agekey

# Lattice workspace operational state (test workspaces)
.lattice/

# Internal planning notes (local only; not published or synced to site)
docs/internal/

# Logs
*.log

# Playwright (desktop perf harness)
apps/desktop/playwright-report/
apps/desktop/test-results/

# Local worktrees
.worktrees/

# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
