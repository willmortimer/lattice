{
  "format": "lattice-workspace-template",
  "version": 2,
  "id": "data-lab",
  "order": 40,
  "name": "Data Lab",
  "category": "Data & Advanced",
  "description": "Organize data sources, queries, notebooks, dashboards, reports, and reusable analysis.",
  "visibility": "gallery",
  "recommended": false,
  "recommendedTitle": "Data Lab",
  "directories": [
    { "path": "Connections", "purpose": "Database, API, and file connection definitions." },
    { "path": "Data", "purpose": "Canonical datasets and curated tables." },
    { "path": "Queries", "purpose": "Reusable SQL and saved query definitions." },
    { "path": "Notebooks", "purpose": "Reproducible analysis notebooks." },
    { "path": "Dashboards", "purpose": "Interactive summaries and charts." },
    { "path": "Reports", "purpose": "Narrative findings and published analysis." },
    { "path": "Archive", "purpose": "Deprecated datasets and old reports." }
  ],
  "preview": [
    "Home.md",
    "Data/contacts.csv",
    "Queries/example.sql",
    "Notebooks/example.ipynb",
    "Connections/",
    "Data/",
    "Queries/",
    "Notebooks/"
  ],
  "files": [
    "Home.md",
    "Data/contacts.csv",
    "Queries/example.sql",
    "Notebooks/example.ipynb"
  ],
  "dataPackages": [
    {
      "path": "Data/metrics.data",
      "title": "Metrics",
      "table": "metrics",
      "columns": [
        { "name": "metric", "type": "text" },
        { "name": "value", "type": "decimal" },
        { "name": "recorded_on", "type": "date" },
        { "name": "category", "type": "text" }
      ],
      "rows": [
        {
          "metric": "active_users",
          "value": 128,
          "recorded_on": "2026-07-01",
          "category": "Engagement"
        },
        {
          "metric": "query_latency_ms",
          "value": 42.5,
          "recorded_on": "2026-07-01",
          "category": "Performance"
        },
        {
          "metric": "active_users",
          "value": 142,
          "recorded_on": "2026-07-08",
          "category": "Engagement"
        },
        {
          "metric": "query_latency_ms",
          "value": 38.2,
          "recorded_on": "2026-07-08",
          "category": "Performance"
        },
        {
          "metric": "error_rate_pct",
          "value": 0.3,
          "recorded_on": "2026-07-08",
          "category": "Reliability"
        }
      ],
      "views": [
        {
          "name": "Board",
          "layout": "board",
          "group_by": "category",
          "columns": ["metric", "value", "category"]
        },
        {
          "name": "Calendar",
          "layout": "calendar",
          "date_field": "recorded_on"
        },
        {
          "name": "Gallery",
          "layout": "gallery",
          "cover_field": "metric"
        },
        {
          "name": "Form",
          "layout": "form"
        }
      ]
    }
  ],
  "capabilities": ["pages", "canvas", "sqlite", "jupyter"],
  "workspaceDefaults": {
    "quickNoteDirectory": "Reports",
    "archiveDirectory": "Archive"
  },
  "openOnCreate": "Home.md"
}
