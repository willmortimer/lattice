{
  "format": "lattice-workspace-template",
  "version": 2,
  "id": "personal",
  "order": 10,
  "name": "Personal",
  "category": "Everyday",
  "description": "Capture ideas, run projects, manage ongoing areas, and keep a durable library.",
  "visibility": "gallery",
  "recommended": true,
  "recommendedTitle": "Personal",
  "directories": [
    { "path": "Inbox", "purpose": "Drop raw captures here — triage them into Projects or Library." },
    { "path": "Projects", "purpose": "Time-bound outcomes with a clear finish line." },
    { "path": "Areas", "purpose": "Ongoing responsibilities to maintain over time." },
    { "path": "Library", "purpose": "Reference material, book notes, and durable knowledge." },
    { "path": "Journal", "purpose": "Daily notes and periodic reflections." },
    { "path": "Templates", "purpose": "Reusable note patterns with {{title}} and {{date}} placeholders." },
    { "path": "Archive", "purpose": "Completed projects and inactive material." }
  ],
  "preview": [
    "Home.md",
    "Projects/Example Project.md",
    "Journal/2026-07-17.md",
    "Templates/Daily.md",
    "Inbox/",
    "Projects/",
    "Journal/"
  ],
  "files": [
    "Home.md",
    "Welcome.md",
    "Projects/Example Project.md",
    "Journal/2026-07-17.md",
    "Templates/Meeting Note.md",
    "Templates/Book Note.md",
    "Templates/Daily.md"
  ],
  "dataPackages": [
    {
      "path": "Tasks.data",
      "title": "Tasks",
      "table": "tasks",
      "columns": [
        { "name": "task", "type": "text" },
        { "name": "status", "type": "text" },
        { "name": "due", "type": "date" }
      ],
      "rows": [
        { "task": "Review inbox", "status": "todo", "due": null },
        { "task": "Plan the week", "status": "todo", "due": "2026-07-21" }
      ]
    }
  ],
  "capabilities": ["pages", "canvas", "sqlite"],
  "workspaceDefaults": {
    "quickNoteDirectory": "Inbox",
    "dailyNoteDirectory": "Journal",
    "templateDirectory": "Templates",
    "archiveDirectory": "Archive"
  },
  "openOnCreate": "Home.md"
}
