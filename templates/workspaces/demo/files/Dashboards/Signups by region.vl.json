{
  "lattice": {
    "data": {
      "dataset": "Data/Events.dataset",
      "sql": "SELECT region, sum(signups) AS signups FROM read_parquet('Data/Events.dataset/facts/**/*.parquet', hive_partitioning = true, union_by_name = true) GROUP BY region ORDER BY region"
    }
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Signups by region",
  "data": { "name": "table" },
  "mark": { "type": "bar", "tooltip": true },
  "encoding": {
    "x": { "field": "region", "type": "nominal", "title": "Region" },
    "y": { "field": "signups", "type": "quantitative", "title": "Signups" },
    "color": { "field": "region", "type": "nominal", "legend": null }
  }
}
