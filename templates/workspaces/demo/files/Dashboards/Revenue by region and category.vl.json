{
  "lattice": {
    "data": {
      "dataset": "Data/Orders.dataset",
      "sql": "SELECT region, category, sum(revenue) AS revenue FROM read_parquet('Data/Orders.dataset/facts/**/*.parquet', hive_partitioning = true, union_by_name = true) GROUP BY region, category ORDER BY region, category"
    }
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Revenue by region and category",
  "data": { "name": "table" },
  "mark": { "type": "bar", "tooltip": true },
  "encoding": {
    "x": { "field": "region", "type": "nominal", "title": "Region", "sort": null },
    "y": { "field": "revenue", "type": "quantitative", "title": "Revenue", "stack": "zero" },
    "color": { "field": "category", "type": "nominal", "title": "Category" }
  }
}
