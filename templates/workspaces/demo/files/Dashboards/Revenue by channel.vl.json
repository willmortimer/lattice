{
  "lattice": {
    "data": {
      "dataset": "Data/Orders.dataset",
      "sql": "SELECT channel, sum(revenue) AS revenue, count(*)::BIGINT AS orders FROM read_parquet('Data/Orders.dataset/facts/**/*.parquet', hive_partitioning = true, union_by_name = true) GROUP BY channel ORDER BY channel"
    }
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Revenue by channel",
  "data": { "name": "table" },
  "layer": [
    {
      "mark": { "type": "bar", "tooltip": true },
      "encoding": {
        "x": { "field": "channel", "type": "nominal", "title": "Channel" },
        "y": { "field": "revenue", "type": "quantitative", "title": "Revenue" },
        "color": { "field": "channel", "type": "nominal", "legend": null }
      }
    },
    {
      "mark": { "type": "line", "point": true, "tooltip": true },
      "encoding": {
        "x": { "field": "channel", "type": "nominal" },
        "y": {
          "field": "orders",
          "type": "quantitative",
          "title": "Orders",
          "axis": { "orient": "right" }
        },
        "color": { "value": "#c45c26" }
      }
    }
  ],
  "resolve": { "scale": { "y": "independent" } }
}
