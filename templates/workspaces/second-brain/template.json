    "Templates/Daily.md",
    "Prompts/"
  ],
  "files": [
    "Home.md",
    "MOCs/Knowledge Base.md",
    "Notes/Capture Workflow.md",
    "Notes/Evergreen Notes.md",
    "Notes/Linking Philosophy.md",
    "Notes/Progressive Summarization.md",
    "Notes/Spaced Repetition.md",
    "Notes/Zettelkasten Primer.md",
    "Context/AGENTS.md",
    "Templates/Daily.md",
    "Prompts/Synthesize Connections.md",
    "Prompts/Weekly Review.md",
    "Prompts/Extract Key Ideas.md"
  ],
  "capabilities": ["pages", "citations"],
