{
  "name": "@lattice/desktop",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "compile-theme": "node ../../scripts/compile-theme.mjs",
    "compile-templates": "node ../../scripts/compile-templates.mjs",
    "predev": "pnpm compile-theme && pnpm compile-templates",
    "dev": "vite",
    "prebuild": "pnpm compile-theme && pnpm compile-templates",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "LATTICE_DEV_HOME=\"$(cd ../.. && pwd)/target/dev-home\" LATTICE_DEV_RESET_DEMO=1 tauri dev --features voice-embedded",
    "tauri:dev:voice-daemon": "LATTICE_DEV_HOME=\"$(cd ../.. && pwd)/target/dev-home\" LATTICE_DEV_RESET_DEMO=1 LATTICE_VOICE_DAEMON=1 tauri dev --features voice",
    "tauri:dev:voice-daemon:fluidaudio": "LATTICE_DEV_HOME=\"$(cd ../.. && pwd)/target/dev-home\" LATTICE_DEV_RESET_DEMO=1 LATTICE_VOICE_DAEMON=1 LATTICE_VOICE_FAKE=0 LATTICE_VOICE_HOST_BIN=\"$(cd ../.. && pwd)/target/debug/lattice-voice-host\" LATTICE_VOICE_MODEL_CACHE=\"$(cd ../.. && pwd)/research/voice-m0-fluidaudio/.cache/Models\" tauri dev --features voice",
    "tauri:dev:e2e": "LATTICE_DEV_HOME=\"$(cd ../.. && pwd)/target/dev-home\" LATTICE_DEV_RESET_DEMO=1 tauri dev --features e2e-testing",
    "tauri:dev:novoice": "LATTICE_DEV_HOME=\"$(cd ../.. && pwd)/target/dev-home\" LATTICE_DEV_RESET_DEMO=1 tauri dev",
    "tauri:dev:keep": "LATTICE_DEV_HOME=\"$(cd ../.. && pwd)/target/dev-home\" tauri dev --features voice-embedded",
    "tauri:build": "tauri build --features voice-embedded",
    "tauri:build:novoice": "tauri build",
    "test": "vitest run",
    "test:perf": "playwright test --project=browser",
    "test:perf:tauri": "node ./e2e/run-tauri-perf.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@finos/perspective": "^3.8.0",
    "@finos/perspective-viewer": "^3.8.0",
    "@finos/perspective-viewer-datagrid": "^3.8.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@glideapps/glide-data-grid": "^6.0.3",
    "@lattice/ui": "workspace:*",
    "@lezer/highlight": "^1.2.3",
    "@phosphor-icons/react": "^2.1.10",
    "@shikijs/langs": "4.3.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/extension-table-cell": "^3.28.0",
    "@tiptap/extension-table-header": "^3.28.0",
    "@tiptap/extension-table-row": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "apache-arrow": "^21.1.0",
    "dompurify": "^3.4.12",
    "markdown-it": "^14.3.0",
    "mermaid": "^11.16.0",
    "pdfjs-dist": "^6.1.200",
    "pixi.js": "^8.19.0",
    "prosemirror-markdown": "^1.13.5",
    "prosemirror-model": "^1.25.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@srsholmes/tauri-playwright": "0.4.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
