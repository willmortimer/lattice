---
import Layout from '../layouts/Layout.astro';
import HeroLattice from '../components/HeroLattice.astro';
import DirectoryTree from '../components/DirectoryTree.astro';
import WorkspaceConstellation from '../components/WorkspaceConstellation.astro';
import CloudHorizon from '../components/CloudHorizon.astro';

const surfaces = [
  {
    label: 'Write',
    title: 'Pages that stay Markdown',
    body: 'Capture quickly, write with a focused editor, connect ideas with links and backlinks, and embed the rest of your workspace without giving up a readable file.',
    href: '/features/#notes',
  },
  {
    label: 'Arrange',
    title: 'A canvas for spatial thinking',
    body: 'Place pages, files, notes, and data views on an open JSON Canvas. Move from a visual map back into the source resource in one step.',
    href: '/features/#canvas',
  },
  {
    label: 'Organize',
    title: 'Tables that grow with the work',
    body: 'Use a fast typed grid, then add views, forms, relations, formulas, lookups, rollups, and interfaces when a simple list becomes an application.',
    href: '/features/#data',
  },
  {
    label: 'Compute',
    title: 'Data, notebooks, and local tasks',
    body: 'Explore Parquet with DuckDB, chart and map results, run Jupyter notebooks, and turn repeatable local code into inspectable tasks and workflows.',
    href: '/features/#automation',
  },
];

const available = [
  'Markdown pages & quick capture',
  'Links, backlinks & hybrid search',
  'Editable JSON Canvas',
  'SQLite data apps & saved views',
  'DuckDB, Parquet, charts & maps',
  'Native and Pyodide notebooks',
  'Tasks, workflows & proposals',
  'Sandboxed artifacts & interfaces',
];
---

<Layout
  title="Lattice — notes, data, and tools that stay yours"
  description="A free, local-first desktop workspace for notes, canvases, tables, datasets, notebooks, and automation. No account required; your work stays in ordinary files."
>
  <section class="hero home-hero">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Free · local-first · open source</p>
          <h1>
            Notes that can grow into <span class="accent">anything.</span>
          </h1>
          <p class="lede">
            Lattice is a fast desktop workspace for writing, thinking, organizing data, and
            running local tools. It works offline and keeps every workspace in a folder you own.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="/docs/getting-started/">Get started</a>
            <a class="btn btn-ghost" href="/features/">Explore features</a>
          </div>
          <div class="hero-meta" aria-label="Product promises">
            <span>No account required</span><span aria-hidden="true">·</span>
            <span>Local by default</span><span aria-hidden="true">·</span>
            <span>Your files stay readable</span>
          </div>
        </div>
        <div class="hero-figure">
          <HeroLattice />
        </div>
      </div>
    </div>
  </section>

  <section class="proof-strip" aria-label="Available features">
    <div class="wrap">
      <p><strong>Available in the local app</strong></p>
      <div class="proof-list">
        {available.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </section>

  <section class="section" id="workspace">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">One calm workspace</p>
        <h2>Start with a note. Add structure only when it helps.</h2>
        <p>
          Lattice keeps the everyday vocabulary small—Page, Canvas, Table, Notebook, and File—
          while giving each kind of work a serious native surface.
        </p>
      </div>
      <div class="surface-grid reveal">
        {surfaces.map((surface) => (
          <a class="surface-card" href={surface.href}>
            <span class="surface-label">{surface.label}</span>
            <h3>{surface.title}</h3>
            <p>{surface.body}</p>
            <span class="surface-link">See how it works <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="compose">
    <div class="wrap">
      <div class="feature reverse">
        <div class="feature-body reveal">
          <p class="eyebrow">Connected, not flattened</p>
          <h3>Every resource keeps its strengths.</h3>
          <p>
            Pages remain great documents. Tables use a real database. Analytical data stays
            columnar. Notebooks remain Jupyter-compatible. Links, embeds, search, history, and
            one command system make them feel like parts of the same place.
          </p>
          <ul class="feature-list">
            <li>Embed live resources in pages and place them on canvas.</li>
            <li>Run tasks and workflows with visible inputs, outputs, and logs.</li>
            <li>Review proposed changes before automation writes to your workspace.</li>
          </ul>
          <p class="feature-cta"><a href="/features/">Tour every workspace surface →</a></p>
        </div>
        <div class="figure reveal">
          <WorkspaceConstellation />
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="directory">
    <div class="wrap">
      <div class="feature">
        <div class="feature-body reveal">
          <p class="eyebrow">A real directory</p>
          <h3>The app is optional. Your work is not.</h3>
          <p>
            A Lattice workspace is an ordinary folder. Open it in Finder, Git, VS Code, a backup
            tool, or another format-aware app. There is no export ceremony between you and your
            own information.
          </p>
          <ul class="feature-list">
            <li>Markdown for pages, JSON Canvas for spatial work, and ipynb for notebooks.</li>
            <li>SQLite for mutable tables; Parquet and DuckDB for analytical data.</li>
            <li>External edits are detected and reconciled instead of silently overwritten.</li>
          </ul>
          <p class="feature-cta"><a href="/docs/concepts/">Understand the workspace model →</a></p>
        </div>
        <div class="figure reveal">
          <DirectoryTree />
          <p class="figure-caption">One workspace, visible on disk</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cloud-section" id="cloud">
    <div class="wrap">
      <div class="feature reverse">
        <div class="feature-body reveal">
          <p class="eyebrow">Local first. Cloud when you want it.</p>
          <h3>The local app is free. Managed sync will be optional.</h3>
          <p>
            Lattice is useful without an account or network connection. Lattice Cloud is being
            designed as a paid convenience layer for encrypted sync, sharing, backups, teams,
            hosted execution, and publishing—not as the place your files become trapped.
          </p>
          <div class="availability-note">
            <span class="status-dot status-dot-local"></span>
            <strong>Local workspace:</strong> available now
          </div>
          <div class="availability-note">
            <span class="status-dot status-dot-cloud"></span>
            <strong>Managed cloud:</strong> in development
          </div>
          <p class="feature-cta"><a href="/features/#cloud">See the local and cloud plan →</a></p>
        </div>
        <div class="figure reveal">
          <CloudHorizon />
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="cta">
    <div class="wrap">
      <div class="cta-band reveal">
        <p class="eyebrow centered-eyebrow">Make a workspace yours</p>
        <h2>Write locally. Build outward when you’re ready.</h2>
        <p>
          Begin with the desktop workflow, explore the First Look workspace, or inspect the entire
          open-source implementation.
        </p>
        <div class="cta-actions">
          <a class="btn btn-primary" href="/docs/getting-started/">Read the quick start</a>
          <a class="btn btn-ghost" href="https://github.com/willmortimer/lattice">View on GitHub</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
