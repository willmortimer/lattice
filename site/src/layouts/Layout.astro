---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/theme.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lattice — the open information studio',
  description = 'Lattice is a fast, local-first, open-native workspace for documents, data applications, analytical datasets, notebooks, canvases, ink, dashboards, and inspectable automations — all stored as plain files in a real directory.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230a0d13'/%3E%3Cpath d='M8 16 L16 8 L24 16 L16 24 Z' fill='none' stroke='%23f5a623' stroke-width='1.6'/%3E%3Ccircle cx='16' cy='16' r='2.6' fill='%23f5a623'/%3E%3C/svg%3E"
    />
  </head>
  <body class="marketing">
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/">
          <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path
              d="M6 16 L16 6 L26 16 L16 26 Z"
              fill="none"
              stroke="var(--l-amber)"
              stroke-width="1.5"
            ></path>
            <path d="M16 6 L16 26 M6 16 L26 16" stroke="var(--l-amber)" stroke-width="1" opacity="0.5"
            ></path>
            <circle cx="16" cy="16" r="2.6" fill="var(--l-amber)"></circle>
            <circle cx="16" cy="6" r="1.7" fill="var(--l-amber-bright)"></circle>
            <circle cx="16" cy="26" r="1.7" fill="var(--l-amber-bright)"></circle>
            <circle cx="6" cy="16" r="1.7" fill="var(--l-amber-bright)"></circle>
            <circle cx="26" cy="16" r="1.7" fill="var(--l-amber-bright)"></circle>
          </svg>
          Lattice
        </a>
        <nav class="nav">
          <a class="nav-hide" href="/#directory">Real directory</a>
          <a class="nav-hide" href="/#command">One command</a>
          <a class="nav-hide" href="/#roadmap">Roadmap</a>
          <a href="/docs/">Docs</a>
          <a class="nav-cta" href="https://github.com">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="footer-grid">
          <div class="footer-brand">
            <a class="brand" href="/">
              <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
                <path
                  d="M6 16 L16 6 L26 16 L16 26 Z"
                  fill="none"
                  stroke="var(--l-amber)"
                  stroke-width="1.5"></path>
                <circle cx="16" cy="16" r="2.6" fill="var(--l-amber)"></circle>
              </svg>
              Lattice
            </a>
            <p>
              A fast, local-first, open-native workspace. Your work stays in a real directory of
              open files — no lock-in, no bundled brain.
            </p>
          </div>
          <div class="footer-cols">
            <div class="footer-col">
              <h5>Product</h5>
              <a href="/#directory">Real directory</a>
              <a href="/#command">One command core</a>
              <a href="/#data">Large data</a>
              <a href="/#roadmap">Roadmap</a>
            </div>
            <div class="footer-col">
              <h5>Documentation</h5>
              <a href="/docs/">Overview</a>
              <a href="/docs/01-product-vision/">Product vision</a>
              <a href="/docs/04-system-architecture/">Architecture</a>
              <a href="/docs/decisions/">Decisions (ADRs)</a>
            </div>
            <div class="footer-col">
              <h5>Project</h5>
              <a href="https://github.com">GitHub</a>
              <a href="/docs/29-roadmap/">Roadmap</a>
              <a href="/docs/35-licensing-governance-and-sustainability/">Licensing</a>
            </div>
          </div>
        </div>
        <div class="footer-legal">
          <span>Lattice — open-native workspace. Specification-stage project.</span>
          <span class="mono">Markdown · SQLite · Parquet · JSON Canvas · ipynb</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var prefersReduced =
          window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var els = document.querySelectorAll('.reveal');
        if (prefersReduced || !('IntersectionObserver' in window)) {
          els.forEach(function (el) {
            el.classList.add('in');
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
