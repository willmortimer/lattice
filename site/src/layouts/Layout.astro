---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/theme.css';
import GridGlints from '../components/GridGlints.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lattice — local-first notes, data, and tools',
  description = 'Lattice is a free, local-first desktop workspace for notes, canvases, tables, datasets, notebooks, and local automation. Your work stays in ordinary files and remains useful offline.',
} = Astro.props;

const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230a0d13'/%3E%3Cg stroke='%23f5a623' stroke-linecap='round' fill='none'%3E%3Cpath d='M16 3.8L26.57 9.9M26.57 9.9L26.57 22.1M26.57 22.1L16 28.2M16 28.2L5.43 22.1M5.43 22.1L5.43 9.9M5.43 9.9L16 3.8' stroke-width='1.6' opacity='0.9'/%3E%3Cpath d='M16 16L26.57 9.9M16 16L5.43 9.9M16 16L16 28.2' stroke-width='1.6'/%3E%3C/g%3E%3Ccircle cx='16' cy='16' r='2.3' fill='%23f5a623'/%3E%3C/svg%3E"
    />
  </head>
  <body class="marketing">
    <GridGlints />
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/">
          <!-- Generated by site/scripts/generate-mark.mjs — do not hand-edit. -->
          <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <g stroke="var(--l-amber)" stroke-linecap="round">
              <path d="M16 16L27.43 22.6M16 16L16 2.8M16 16L4.57 22.6" stroke-width="0.98" opacity="0.28"></path>
              <path d="M21.72 6.1L10.28 12.7M10.28 6.1L21.72 12.7M27.43 16L16 22.6M21.72 25.9L21.72 12.7M10.28 25.9L10.28 12.7M4.57 16L16 22.6" stroke-width="1.05" opacity="0.45"></path>
              <path d="M16 2.8L27.43 9.4M27.43 9.4L27.43 22.6M27.43 22.6L16 29.2M16 29.2L4.57 22.6M4.57 22.6L4.57 9.4M4.57 9.4L16 2.8" stroke-width="1.4" opacity="0.9"></path>
              <path d="M16 16L27.43 9.4M16 16L4.57 9.4M16 16L16 29.2" stroke-width="1.4" opacity="0.95"></path>
            </g>
            <g fill="var(--l-amber-bright)">
              <circle cx="16" cy="2.8" r="1.65"></circle>
              <circle cx="27.43" cy="9.4" r="1.65"></circle>
              <circle cx="27.43" cy="22.6" r="1.65"></circle>
              <circle cx="16" cy="29.2" r="1.65"></circle>
              <circle cx="4.57" cy="22.6" r="1.65"></circle>
              <circle cx="4.57" cy="9.4" r="1.65"></circle>
            </g>
            <circle cx="16" cy="16" r="2.51" fill="var(--l-amber)"></circle>
          </svg>
          Lattice
        </a>
        <nav class="nav">
          <a class="nav-hide" href="/features/" aria-current={path.startsWith('/features') ? 'page' : undefined}>Features</a>
          <a class="nav-hide" href="/features/#cloud">Cloud</a>
          <a href="/docs/" aria-current={path.startsWith('/docs') ? 'page' : undefined}>Docs</a>
          <a class="nav-cta" href="https://github.com/willmortimer/lattice">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="footer-grid">
          <div class="footer-brand">
            <a class="brand" href="/">
              <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
                <g stroke="var(--l-amber)" stroke-linecap="round">
                  <path d="M16 2.8L27.43 9.4M27.43 9.4L27.43 22.6M27.43 22.6L16 29.2M16 29.2L4.57 22.6M4.57 22.6L4.57 9.4M4.57 9.4L16 2.8" stroke-width="1.4" opacity="0.9"></path>
                  <path d="M16 16L27.43 9.4M16 16L4.57 9.4M16 16L16 29.2" stroke-width="1.4" opacity="0.95"></path>
                </g>
                <circle cx="16" cy="16" r="2.51" fill="var(--l-amber)"></circle>
              </svg>
              Lattice
            </a>
            <p>
              A free, local-first workspace for notes, data, and tools. Fast on your computer,
              understandable on disk, and ready for optional cloud sync later.
            </p>
          </div>
          <div class="footer-cols">
            <div class="footer-col">
              <h5>Product</h5>
              <a href="/features/">Features</a>
              <a href="/features/#notes">Notes & capture</a>
              <a href="/features/#data">Tables & analytics</a>
              <a href="/features/#automation">Compute & automation</a>
              <a href="/features/#cloud">Lattice Cloud</a>
            </div>
            <div class="footer-col">
              <h5>Documentation</h5>
              <a href="/docs/">Overview</a>
              <a href="/docs/getting-started/">Getting started</a>
              <a href="/docs/pages-and-capture/">Pages & capture</a>
              <a href="/docs/tables-and-data-apps/">Tables & data apps</a>
              <a href="/docs/notebooks-tasks-workflows/">Notebooks & tasks</a>
            </div>
            <div class="footer-col">
              <h5>Project</h5>
              <a href="https://github.com/willmortimer/lattice">GitHub</a>
              <a href="/docs/roadmap/">Roadmap</a>
              <a href="/docs/cloud-and-sync/">Cloud & sync</a>
              <a href="https://github.com/willmortimer/lattice/blob/main/LICENSE">Licensing</a>
            </div>
          </div>
        </div>
        <div class="footer-legal">
          <span>Free local app · optional paid cloud services are in development.</span>
          <span class="mono">Markdown · SQLite · Parquet · JSON Canvas · ipynb</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var prefersReduced =
          window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var els = document.querySelectorAll('.reveal');
        if (prefersReduced || !('IntersectionObserver' in window)) {
          els.forEach(function (el) {
            el.classList.add('in');
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
