---
import { CENTER, NEAR, OUTLINE, VERTICES, project } from '../lib/lattice-geometry.mjs';

const cx = 320;
const cy = 210;
const scale = 80;
const expand = ([x, y, z]: [number, number, number]) => [x * 2, y * 2, z * 2] as [number, number, number];
const scenePoint = (point: [number, number, number]) => {
  const [px, py] = project(point);
  return { x: cx + px * scale, y: cy + py * scale, key: point.join(':') };
};
const segment = ([from, to]: [[number, number, number], [number, number, number]]) => ({
  from: scenePoint(expand(from)),
  to: scenePoint(expand(to)),
});

const activeSegments = [...OUTLINE, ...NEAR].map(segment);
const activePoints = [...VERTICES, CENTER].map((point) => scenePoint(expand(point)));
const labels = ['Page', 'Canvas', 'Table', 'Dataset', 'Notebook', 'Task', 'Workspace'];

const scaffoldPoints = [];
const scaffoldEdges = [];
for (let x = 0; x <= 2; x++) {
  for (let y = 0; y <= 2; y++) {
    for (let z = 0; z <= 2; z++) {
      const from = scenePoint([x, y, z]);
      scaffoldPoints.push(from);
      if (x < 2) scaffoldEdges.push({ from, to: scenePoint([x + 1, y, z]) });
      if (y < 2) scaffoldEdges.push({ from, to: scenePoint([x, y + 1, z]) });
      if (z < 2) scaffoldEdges.push({ from, to: scenePoint([x, y, z + 1]) });
    }
  }
}
---

<svg class="workspace-constellation" viewBox="0 0 640 430" role="img" aria-labelledby="constellation-title constellation-desc">
  <title id="constellation-title">Lattice resource constellation</title>
  <desc id="constellation-desc">Pages, canvases, tables, datasets, notebooks, and tasks joined in one local workspace.</desc>
  <defs>
    <radialGradient id="constellationGlow">
      <stop offset="0" stop-color="var(--l-amber-bright)" stop-opacity=".9" />
      <stop offset="1" stop-color="var(--l-amber)" stop-opacity="0" />
    </radialGradient>
  </defs>
  <g class="constellation-scaffold">
    {scaffoldEdges.map(({ from, to }) => <line x1={from.x} y1={from.y} x2={to.x} y2={to.y} />)}
    {scaffoldPoints.map((point) => <circle cx={point.x} cy={point.y} r="1.5" />)}
  </g>
  <g class="constellation-cell">
    {activeSegments.map(({ from, to }, index) => (
      <line x1={from.x} y1={from.y} x2={to.x} y2={to.y} pathLength="1" style={`--i:${index}`} />
    ))}
  </g>
  <g class="constellation-nodes">
    {activePoints.map((point, index) => (
      <g class:list={['constellation-node', { anchor: index === activePoints.length - 1 }]} style={`--i:${index}`}>
        <circle class="constellation-halo" cx={point.x} cy={point.y} r={index === activePoints.length - 1 ? 34 : 24} fill="url(#constellationGlow)" />
        <circle class="constellation-core" cx={point.x} cy={point.y} r={index === activePoints.length - 1 ? 6 : 4} />
        <text
          x={point.x + (index === 1 || index === 2 ? 22 : index === 4 || index === 5 ? -22 : 0)}
          y={point.y + (index === 0 ? -18 : index === 3 ? 30 : index === 6 ? -14 : 5)}
          text-anchor={index === 1 || index === 2 ? 'start' : index === 4 || index === 5 ? 'end' : 'middle'}
        >{labels[index]}</text>
      </g>
    ))}
  </g>
</svg>

<style>
  .workspace-constellation { display: block; width: 100%; height: auto; overflow: visible; }
  .constellation-scaffold { stroke: var(--l-line-strong); fill: var(--l-faint); opacity: .45; stroke-width: 1; }
  .constellation-cell { stroke: var(--l-amber); stroke-width: 2; stroke-linecap: round; }
  .constellation-cell line {
    stroke-dasharray: 1;
    animation: constellation-trace 6.8s cubic-bezier(.22, 1, .36, 1) infinite;
    animation-delay: calc(var(--i) * 110ms);
    animation-fill-mode: backwards;
  }
  .constellation-node { color: var(--l-amber-bright); fill: currentColor; }
  .constellation-core { transform-box: fill-box; transform-origin: center; animation: constellation-node 6.8s ease-in-out infinite; animation-delay: calc(var(--i) * 130ms); }
  .constellation-halo { opacity: .12; transform-box: fill-box; transform-origin: center; animation: constellation-wake 6.8s ease-out infinite; animation-delay: calc(var(--i) * 130ms); }
  .constellation-node.anchor .constellation-halo { opacity: .28; }
  .constellation-node text { fill: var(--l-text-soft); font-family: var(--l-font-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; }
  @keyframes constellation-trace {
    0%, 5% { stroke-dashoffset: 1; opacity: .08; }
    18%, 86% { stroke-dashoffset: 0; opacity: .95; }
    100% { stroke-dashoffset: 0; opacity: .48; }
  }
  @keyframes constellation-node {
    0%, 8% { opacity: .32; transform: scale(.78); }
    18%, 88% { opacity: 1; transform: scale(1); }
    100% { opacity: .55; transform: scale(.9); }
  }
  @keyframes constellation-wake {
    0%, 8% { opacity: 0; transform: scale(.5); }
    20% { opacity: .8; transform: scale(1.15); }
    34%, 100% { opacity: .1; transform: scale(.75); }
  }
  @media (prefers-reduced-motion: reduce) {
    .constellation-cell line, .constellation-core, .constellation-halo { animation: none; }
  }
</style>
