---
/**
 * "Large data is first-class": an illustrative, hand-built SVG bar chart on a
 * log scale contrasting typical hosted-table row ceilings with what a local
 * Parquet/DuckDB workspace handles. Bars draw in via CSS on scroll.
 * Figures are illustrative, not benchmarked.
 */
const bars = [
  { label: 'Hosted table A', value: 50_000, accent: false },
  { label: 'Hosted table B', value: 250_000, accent: false },
  { label: 'Lattice · SQLite app', value: 5_000_000, accent: true },
  { label: 'Lattice · Parquet + DuckDB', value: 1_000_000_000, accent: true },
];

const W = 640;
const H = 360;
const baseY = 288;
const topY = 40;
const plotH = baseY - topY;
const leftPad = 58;
const rightPad = 24;
const plotW = W - leftPad - rightPad;
const logTop = 9; // 10^9 ceiling
const barW = 78;
const slot = plotW / bars.length;

function fracOf(v) {
  return Math.log10(v) / logTop;
}
function fmt(v) {
  if (v >= 1_000_000_000) return v / 1_000_000_000 + 'B';
  if (v >= 1_000_000) return v / 1_000_000 + 'M';
  if (v >= 1_000) return v / 1_000 + 'K';
  return String(v);
}
const ticks = [1_000, 100_000, 10_000_000, 1_000_000_000];
---

<svg
  class="data-chart"
  viewBox={`0 0 ${W} ${H}`}
  fill="none"
  role="img"
  aria-label="Illustrative log-scale chart contrasting hosted-table row limits with local Parquet and DuckDB capacity"
  xmlns="http://www.w3.org/2000/svg"
>
  <style>
    .data-chart { width: 100%; height: auto; }
    .data-chart .axis { font-family: var(--l-font-mono); font-size: 11px; fill: var(--l-faint); }
    .data-chart .cat { font-family: var(--l-font-body); font-size: 12px; fill: var(--l-text-soft); }
    .data-chart .val { font-family: var(--l-font-mono); font-size: 12.5px; font-weight: 600; }
    .data-chart .bar { transform: scaleY(0); transform-origin: bottom; transform-box: fill-box; }
    .reveal.in .data-chart .bar { animation: grow 1.1s cubic-bezier(0.22,1,0.36,1) forwards; }
    @keyframes grow { to { transform: scaleY(1); } }
    .data-chart .valtxt { opacity: 0; }
    .reveal.in .data-chart .valtxt { animation: fadein 0.5s ease forwards; }
    @keyframes fadein { to { opacity: 1; } }
  </style>

  <!-- gridlines + y ticks -->
  {
    ticks.map((t) => {
      const y = baseY - fracOf(t) * plotH;
      return (
        <g>
          <line x1={leftPad} y1={y} x2={W - rightPad} y2={y} stroke="var(--l-line)" stroke-width="1" />
          <text class="axis" x={leftPad - 10} y={y + 4} text-anchor="end">
            {fmt(t)}
          </text>
        </g>
      );
    })
  }
  <line x1={leftPad} y1={baseY} x2={W - rightPad} y2={baseY} stroke="var(--l-line-strong)" stroke-width="1.2" />

  <!-- bars -->
  {
    bars.map((b, i) => {
      const h = fracOf(b.value) * plotH;
      const cx = leftPad + slot * i + slot / 2;
      const x = cx - barW / 2;
      const y = baseY - h;
      const fill = b.accent ? 'var(--l-amber)' : 'rgba(140,162,196,0.28)';
      const stroke = b.accent ? 'var(--l-amber-bright)' : 'rgba(140,162,196,0.5)';
      return (
        <g>
          <rect
            class="bar"
            x={x}
            y={y}
            width={barW}
            height={h}
            rx="4"
            fill={fill}
            stroke={stroke}
            stroke-width="1"
            style={`animation-delay:${(i * 0.16).toFixed(2)}s`}
          />
          <text
            class="val valtxt"
            x={cx}
            y={y - 10}
            text-anchor="middle"
            fill={b.accent ? 'var(--l-amber-bright)' : 'var(--l-muted)'}
            style={`animation-delay:${(i * 0.16 + 0.5).toFixed(2)}s`}
          >
            {fmt(b.value)}
          </text>
          <text class="cat" x={cx} y={baseY + 20} text-anchor="middle">
            {b.label.split(' · ')[0]}
          </text>
          {b.label.includes(' · ') && (
            <text class="cat" x={cx} y={baseY + 35} text-anchor="middle" fill="var(--l-faint)">
              {b.label.split(' · ')[1]}
            </text>
          )}
        </g>
      );
    })
  }

  <text class="axis" x={leftPad} y={topY - 16} fill="var(--l-faint)">
    rows handled locally — log scale · illustrative
  </text>
</svg>
