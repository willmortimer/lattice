---
/**
 * The hero is the brand algorithm expanded into a small 3D lattice.
 * Geometry is derived from the same 30° axonometric projection used by
 * generate-mark.mjs; only scale, subdivision, and signal routes differ.
 */
const tilt = Math.PI / 6;
const ax = Math.cos(tilt);
const ay = Math.sin(tilt);
const count = 4;
const scale = 68;
const cx = 330;
const cy = 230;

const project = (x, y, z) => ({
  x: cx + (x - z) * ax * scale,
  y: cy + ((x + z) * ay - y) * scale,
  depth: x + y + z,
  key: `${x}:${y}:${z}`,
});

const points = [];
for (let x = 0; x < count; x++) {
  for (let y = 0; y < count; y++) {
    for (let z = 0; z < count; z++) points.push(project(x, y, z));
  }
}

const edges = [];
for (let x = 0; x < count; x++) {
  for (let y = 0; y < count; y++) {
    for (let z = 0; z < count; z++) {
      const from = project(x, y, z);
      if (x + 1 < count) edges.push({ from, to: project(x + 1, y, z) });
      if (y + 1 < count) edges.push({ from, to: project(x, y + 1, z) });
      if (z + 1 < count) edges.push({ from, to: project(x, y, z + 1) });
    }
  }
}

const routeCoords = [
  [0, 1, 0],
  [1, 1, 0],
  [1, 2, 0],
  [1, 2, 1],
  [2, 2, 1],
  [2, 2, 2],
  [3, 2, 2],
  [3, 3, 2],
];
const route = routeCoords.map(([x, y, z]) => project(x, y, z));
const routeSegments = route.slice(1).map((to, i) => ({ from: route[i], to }));
---

<svg
  class="hero-lattice"
  viewBox="0 0 660 470"
  fill="none"
  role="img"
  aria-label="An axonometric lattice carrying a signal through addressable nodes"
>
  <defs>
    <radialGradient id="axonGlow">
      <stop offset="0" stop-color="var(--l-amber-bright)" stop-opacity=".8" />
      <stop offset="1" stop-color="var(--l-amber)" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="depthFade" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="var(--l-line)" />
      <stop offset=".55" stop-color="var(--l-line-strong)" />
      <stop offset="1" stop-color="var(--l-muted)" stop-opacity=".65" />
    </linearGradient>
  </defs>

  <g class="axon-structure" stroke="url(#depthFade)" stroke-linecap="round">
    {
      edges.map(({ from, to }) => (
        <line
          x1={from.x}
          y1={from.y}
          x2={to.x}
          y2={to.y}
          opacity={0.2 + ((from.depth + to.depth) / 18) * 0.45}
        />
      ))
    }
  </g>

  <g class="axon-route" stroke="var(--l-amber)" stroke-linecap="round">
    {
      routeSegments.map(({ from, to }, index) => (
        <line
          x1={from.x}
          y1={from.y}
          x2={to.x}
          y2={to.y}
          style={`--delay:${index * 0.22}s`}
        />
      ))
    }
  </g>

  <g class="axon-nodes" fill="var(--l-faint)">
    {points.map((point) => <circle cx={point.x} cy={point.y} r="1.65" />)}
  </g>

  <g class="axon-signal">
    {
      route.map((point, index) => (
        <g style={`--delay:${index * 0.22 + 0.4}s`}>
          <circle class="signal-halo" cx={point.x} cy={point.y} r="18" fill="url(#axonGlow)" />
          <circle cx={point.x} cy={point.y} r={index === route.length - 1 ? 4.8 : 3.1} />
        </g>
      ))
    }
  </g>

  <g class="axon-labels">
    <text x="30" y="424">real directory</text>
    <text x="505" y="76">semantic command</text>
    <text x="490" y="430">open resource</text>
  </g>
</svg>

<style>
  .hero-lattice {
    display: block;
    width: 100%;
    height: auto;
  }
  .axon-structure line {
    stroke-width: 1;
  }
  .axon-route line {
    stroke-width: 2;
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    animation: axon-draw 1.15s cubic-bezier(.22, 1, .36, 1) forwards;
    animation-delay: var(--delay);
  }
  .axon-signal g {
    color: var(--l-amber-bright);
    fill: currentColor;
    opacity: 0;
    animation: axon-node .7s cubic-bezier(.34, 1.56, .64, 1) forwards;
    animation-delay: var(--delay);
  }
  .signal-halo {
    transform-box: fill-box;
    transform-origin: center;
    animation: axon-breathe 3.2s ease-in-out infinite;
  }
  .axon-labels {
    fill: var(--l-faint);
    font-family: var(--l-font-mono);
    font-size: 10px;
    letter-spacing: .1em;
    text-transform: uppercase;
  }
  @keyframes axon-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes axon-node {
    from { opacity: 0; transform: scale(.55); transform-origin: center; }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes axon-breathe {
    50% { opacity: .35; transform: scale(.72); }
  }
</style>
