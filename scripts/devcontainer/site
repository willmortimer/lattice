#!/usr/bin/env bash
# Astro marketing + Starlight docs. Binds 0.0.0.0:4321 for published ports / Serve.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# shellcheck source=./_env.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_env.sh"
cd "${ROOT}"

if ! command -v pnpm >/dev/null 2>&1; then
  corepack prepare pnpm@11.11.0 --activate
fi

pnpm install
exec pnpm --filter @lattice/site dev -- --host 0.0.0.0 --port 4321
