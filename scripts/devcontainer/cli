#!/usr/bin/env bash
# Build the headless `lattice` CLI. Debug by default; pass --release or set
# LATTICE_CLI_RELEASE=1 for a release build.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# shellcheck source=./_env.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_env.sh"
cd "${ROOT}"

BUILD_ARGS=(build -p lattice-cli)
PROFILE="debug"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --release)
      BUILD_ARGS+=(--release)
      PROFILE="release"
      shift
      ;;
    *)
      BUILD_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ "${LATTICE_CLI_RELEASE:-}" == "1" && " ${BUILD_ARGS[*]} " != *" --release "* ]]; then
  BUILD_ARGS+=(--release)
  PROFILE="release"
fi

cargo "${BUILD_ARGS[@]}"

BIN="$(lattice_cli_bin "${PROFILE}")"
if [[ ! -x "${BIN}" ]]; then
  echo "error: expected binary missing: ${BIN}" >&2
  exit 1
fi
if ! "${BIN}" --help >/dev/null 2>&1; then
  echo "error: lattice binary is not runnable on this host (wrong arch?): ${BIN}" >&2
  exit 1
fi

echo "lattice: ${BIN}"
